from rich.console import Console
from rich.table import Table
from rich.live import Live
from rich.panel import Panel
from rich.align import Align
import random
import time
from datetime import datetime

console = Console()

# Simulated weather data
conditions = ["Sunny", "Cloudy", "Rainy", "Stormy", "Windy"]

def generate_weather():
    return {
        "temperature": random.randint(20, 35),
        "humidity": random.randint(40, 90),
        "condition": random.choice(conditions),
        "wind": random.randint(5, 25)
    }

def create_dashboard(data, history):
    table = Table.grid(expand=True)
    table.add_column(justify="center")

    weather_table = Table(title="🌦️ Weather Dashboard", expand=True)
    weather_table.add_column("Metric", justify="left", style="cyan")
    weather_table.add_column("Value", justify="right", style="magenta")

    weather_table.add_row("Temperature", f"{data['temperature']}°C")
    weather_table.add_row("Humidity", f"{data['humidity']}%")
    weather_table.add_row("Condition", data["condition"])
    weather_table.add_row("Wind Speed", f"{data['wind']} km/h")

    # ASCII temperature trend
    trend = "".join(["▁▂▃▄▅▆▇"[min(6, (t - 20)//2)] for t in history])

    trend_panel = Panel(
        trend,
        title="📈 Temperature Trend",
        border_style="green"
    )

    time_panel = Panel(
        datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        title="⏰ Current Time",
        border_style="blue"
    )

    table.add_row(weather_table)
    table.add_row(trend_panel)
    table.add_row(time_panel)

    return Panel(
        Align.center(table),
        title="🌍 Live Weather Monitor",
        border_style="bright_blue"
    )

def main():
    history = []

    with Live(console=console, refresh_per_second=2) as live:
        while True:
            data = generate_weather()
            history.append(data["temperature"])

            if len(history) > 20:
                history.pop(0)

            dashboard = create_dashboard(data, history)
            live.update(dashboard)

            time.sleep(1)

if __name__ == "__main__":
    main()